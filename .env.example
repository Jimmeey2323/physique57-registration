# Environment Variables Template
# Copy this file to .env and fill in your actual values
# ⚠️  Never commit .env to git – it is listed in .gitignore

# ── Google OAuth (for Google Sheets integration) ──────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
SPREADSHEET_ID=your_google_spreadsheet_id_here

# ── Momence API ──────────────────────────────────────────────────────────────
# MOMENCE_BASIC_AUTH format: "Basic <base64(apiId:apiSecret)>"
MOMENCE_BASIC_AUTH=Basic your_momence_basic_auth_base64_here
# MOMENCE_BEARER_TOKEN format: "Bearer <base64(apiId:apiSecret)>"
MOMENCE_BEARER_TOKEN=Bearer your_momence_bearer_token_here
MOMENCE_USERNAME=your_momence_username_here
MOMENCE_PASSWORD=your_momence_password_here

# ── Mailtrap Email Service (OTP delivery) ────────────────────────────────────
MAILTRAP_API_TOKEN=your_mailtrap_api_token_here
MAILTRAP_FROM_EMAIL=hello@physique57india.com

# ── Vercel deployment ─────────────────────────────────────────────────────────
# Set all of the above as Environment Variables in the Vercel dashboard.
# Do NOT store secrets in source code or commit them to git.
